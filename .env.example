# ── 面板 ──────────────────────────────────────────
DASHBOARD_PORT=8765
DASHBOARD_TITLE=MC 监控
DASHBOARD_REFRESH=5
DATA_DIR=/data

# ── Crafty ───────────────────────────────────────
CRAFTY_URL=https://127.0.0.1:8443
CRAFTY_USERNAME=admin
# 二选一: 明文密码 或 凭据文件(挂载进容器)
CRAFTY_PASSWORD=
CRAFTY_CREDS_FILE=/crafty/config/default-creds.txt
CRAFTY_SERVER_ID=
CRAFTY_TLS_VERIFY=false
CRAFTY_DATA_DIR=/crafty

# ── Minecraft ────────────────────────────────────
MC_HOST=127.0.0.1
MC_RCON_HOST=127.0.0.1
MC_PORT=25565
MC_CONNECT_ADDRESS=your-server.example.com:25565
MC_SERVICE_NAME=MC 服务器
MC_VERSION_LABEL=Paper

# ── 内网穿透 / 隧道探测（可选）──────────────────
TUNNEL_ENABLED=false
TUNNEL_NAME=隧道
TUNNEL_HOST=
TUNNEL_PORT=25565
# auto | systemd | tcp | none
TUNNEL_CHECK=auto
TUNNEL_SYSTEMD_UNIT=frpc

# ── 功能开关 (auto=按环境自动检测) ────────────────
ENABLE_HOST_METRICS=true
ENABLE_PCP=auto
ENABLE_COREPROTECT=auto
ENABLE_GRIMAC=auto
ENABLE_RCON=auto
ENABLE_CRAFTY_BACKUP=true
ENABLE_CONNECTIVITY_PROBE=true
ENABLE_SYSTEMD_LOGS=true

# ── 路径 / 探测 ──────────────────────────────────
ALERT_LOG_PATH=
PCP_LOG_DIR=/var/log/pcp/pmlogger
PROC_ROOT=/proc
PROBE_DIRECT_URL=https://www.cloudflare.com
PROBE_PROXY_URL=https://www.gstatic.com/generate_204
BACKUP_COOLDOWN_HOURS=3
# CoreProtect 放置速率预警(块/分钟,近 60 秒统计)
PLACE_WARN_RATE=400
PLACE_CRITICAL_RATE=800
# latest.log 时间戳为服务器本地时区(Docker 默认 UTC 需指定)
LOG_TZ=Asia/Shanghai
